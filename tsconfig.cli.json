{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/cli",
    "rootDir": "src/cli",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/cli/**/*.ts"],
  "exclude": ["src/cli/**/*.test.ts"]
}
